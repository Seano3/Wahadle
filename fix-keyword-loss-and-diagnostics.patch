commit a4faca361ad806e8ec29c166fc9667f99cb9e8ca
Author: Sean Thornton <sthornton8@outlook.com>
Date:   Sat Jun 20 23:03:36 2026 +0000

    Fix silent keyword data loss, add real diagnostics for the recurring duplicate-row error
    
    Found while investigating why the duplicate-row fix didn't resolve
    the user's error on retry:
    
    - upsertInBatches() defaulted to deduping on a nonexistent 'id'
      field for Datasheets_keywords (it has no id column -- its real
      key is datasheet_id+keyword+model). Every keyword row collapsed
      to the same dedup key and only the LAST keyword in the entire
      export would have survived an apply -- silent, near-total data
      loss for that table, worse than the error it was meant to fix.
      Verified: 3 distinct keyword rows for one datasheet now correctly
      produce 3 upserted rows instead of 1.
    
    - This doesn't explain the recurring 21000 error by itself (it's a
      data-loss bug, not a Postgres rejection), so rather than guess
      further at which table/row is the real source, added concrete
      diagnostics: on a 21000 error, upsertInBatches now re-scans the
      specific failing batch under its assumed key and logs either the
      exact colliding row pair, or -- if no collision is found under
      that key -- an explicit note that the assumed conflict key for
      that table is probably wrong, with a pointer to check 01_schema.sql.
    
    - Both API routes (preview, apply) previously fell back to a
      generic message for any non-Error-instance failure -- which is
      exactly what Supabase/PostgREST errors are (plain objects with
      code/message/details/hint, not real Error instances) -- so the
      actual useful Postgres message was being discarded before it
      ever reached the browser. Now surfaced directly.

diff --git a/app/api/admin/import/apply/route.ts b/app/api/admin/import/apply/route.ts
index 8e0ad4b..da7ff39 100644
--- a/app/api/admin/import/apply/route.ts
+++ b/app/api/admin/import/apply/route.ts
@@ -39,7 +39,19 @@ export async function POST(req: Request) {
     return NextResponse.json({ ok: true });
   } catch (err) {
     console.error("POST /api/admin/import/apply failed:", err);
-    const message = err instanceof Error ? err.message : "Failed to apply the update.";
+    // Supabase/PostgREST errors are plain objects with code/message/
+    // details/hint, NOT real Error instances, so `err instanceof
+    // Error` is false for them and a naive fallback would discard
+    // the actually-useful Postgres message. Surface it directly --
+    // see upsertInBatches in core.ts for the additional diagnostic
+    // logging (which table, which row) this triggers server-side
+    // for code 21000 specifically.
+    const message =
+      err instanceof Error
+        ? err.message
+        : typeof err === "object" && err !== null && "message" in err
+          ? String((err as { message: unknown }).message)
+          : "Failed to apply the update.";
     return NextResponse.json({ error: message }, { status: 500 });
   }
 }
